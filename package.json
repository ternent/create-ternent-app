{
  "name": "@ternent/create-ternent-app",
  "version": "0.1.0-alpha.1",
  "description": "Scaffold replay-first Ternent applications from core runtime to full app shell.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "check": "pnpm lint && pnpm test && pnpm build",
    "lint": "pnpm typecheck",
    "release": "pnpm build && changeset publish",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ternent",
    "scaffold",
    "create-app",
    "typescript",
    "vite"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "bin": {
    "create-ternent-app": "./bin/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ternent/create-ternent-app.git"
  },
  "homepage": "https://github.com/ternent/create-ternent-app#readme",
  "bugs": {
    "url": "https://github.com/ternent/create-ternent-app/issues"
  }
}
